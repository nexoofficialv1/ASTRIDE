NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://localride:change_me@postgres:5432/localride
PGSSL=disable
PGPOOL_MAX=20
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_WITH_LONG_RANDOM_PASSWORD
OPS_USERNAME=ops
OPS_PASSWORD=CHANGE_WITH_LONG_RANDOM_PASSWORD
FINANCE_USERNAME=finance
FINANCE_PASSWORD=CHANGE_WITH_LONG_RANDOM_PASSWORD
ADMIN_PASSWORD_PEPPER=CHANGE_WITH_64_CHAR_RANDOM_SECRET
ADMIN_SESSION_TTL_MS=28800000
ADMIN_MAX_LOGIN_FAILURES=5
ADMIN_LOCK_MS=900000
PROVIDER_CREDENTIALS_MASTER_KEY=CHANGE_WITH_32_BYTE_BASE64_KEY

# Real-time layer
REDIS_URL=redis://redis:6379
WS_HEARTBEAT_SECONDS=25
DRIVER_PRESENCE_TTL_SECONDS=45
GPS_RETENTION_DAYS=90
STRICT_PRODUCTION_STARTUP=false

# Persistent encrypted admin configuration
ASTRIDE_DATA_DIR=/var/lib/astride
RUNTIME_CONFIG_FILE=/var/lib/astride/runtime-config.json
PROVIDER_VAULT_FILE=/var/lib/astride/provider-vault.json
