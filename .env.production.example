NODE_ENV=production
PORT=3333
API_DOMAIN=api.example.com
ADMIN_DOMAIN=control.example.com
ACME_EMAIL=admin@example.com
POSTGRES_DB=localride
POSTGRES_USER=localride
DATABASE_URL=postgresql://localride:CHANGE_ME@postgres:5432/localride
REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM
REDIS_URL=redis://:CHANGE_ME_LONG_RANDOM@redis:6379
ADMIN_BOOTSTRAP_USERNAME=superadmin
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_LONG_RANDOM
ADMIN_SESSION_TTL_MINUTES=30
PASSWORD_PEPPER=CHANGE_ME_32_PLUS_CHARS
CONFIG_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_SECRET
PROVIDER_CREDENTIAL_KEY=CHANGE_ME_LONG_RANDOM
GPS_RETENTION_DAYS=30
DRIVER_PRESENCE_TTL_SECONDS=45
LOG_LEVEL=info
STRICT_PRODUCTION_STARTUP=true
# Runtime provider modes must be switched to live only after credentials are stored.
# Health probes: /health = liveness, /ready = dependencies + production gate.
